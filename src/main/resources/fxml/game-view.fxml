<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.cuatrifasico.battleshi.controller.GameController"
           prefWidth="1280"
           prefHeight="768"
           styleClass="root">

    <!-- Main game content -->
    <HBox alignment="TOP_CENTER" spacing="26">
        <padding>
            <Insets top="26" right="26" bottom="26" left="26"/>
        </padding>

        <!-- Player side -->
        <VBox alignment="TOP_CENTER" spacing="10">
            <Label fx:id="playerNicknameLabel"
                   text="NICK NAME"
                   styleClass="board-title-bar, player-side"
                   maxWidth="Infinity"/>

            <Pane fx:id="playerBoardContainer"/>

            <HBox fx:id="fleetTrayContainer"
                  alignment="CENTER_LEFT"
                  prefHeight="94"/>
        </VBox>

        <!-- Divider between the two boards -->
        <Line endY="584"
              styleClass="board-divider">

            <HBox.margin>
                <Insets left="16" right="16" top="6"/>
            </HBox.margin>

        </Line>

        <!-- Opponent side -->
        <VBox alignment="TOP_CENTER" spacing="10">

            <Label fx:id="opponentNicknameLabel"
                   text="OPPONENT"
                   styleClass="board-title-bar, opponent-side"
                   maxWidth="Infinity"/>

            <Pane fx:id="opponentBoardContainer"/>

            <HBox alignment="CENTER"
                  spacing="12"
                  prefHeight="94">

                <Button fx:id="restartButton"
                        text="􀅈"
                        styleClass="icon-button"/>

                <Button fx:id="playButton"
                        text="􀊄"
                        styleClass="icon-button"
                        disable="true"/>

                <Button fx:id="viewEnemyButton"
                        text="􀋭"
                        styleClass="icon-button"/>

                <Button fx:id="exitButton"
                        text="􀻵"
                        styleClass="icon-button"/>

            </HBox>

        </VBox>

    </HBox>

    <!-- Instructions overlay -->
    <StackPane fx:id="instructionsOverlay"
               styleClass="overlay-scrim">

        <StackPane prefWidth="742"
                   prefHeight="580"
                   maxWidth="742"
                   maxHeight="580">

            <!-- Visible border -->
            <Rectangle
                    arcWidth="28"
                    arcHeight="28"
                    fill="TRANSPARENT"
                    mouseTransparent="true"
                    strokeWidth="2"
                    styleClass="overlay-card-border"
                    width="742"
                    height="580"/>

            <!-- Clipped content -->
            <StackPane fx:id="instructionsCard"
                       prefWidth="742"
                       prefHeight="580"
                       maxWidth="742"
                       maxHeight="580">

                <ImageView fx:id="instructionsImage"
                           fitWidth="742"
                           fitHeight="580"
                           pickOnBounds="true"/>

                <BorderPane prefWidth="742"
                            prefHeight="580">

                    <!-- Previous -->
                    <left>

                        <StackPane BorderPane.alignment="CENTER">

                            <padding>
                                <Insets left="16"/>
                            </padding>

                            <Button fx:id="previousInstructionButton"
                                    text="􀯶"
                                    styleClass="carousel-button"/>

                        </StackPane>

                    </left>

                    <!-- Next -->
                    <right>

                        <StackPane BorderPane.alignment="CENTER">

                            <padding>
                                <Insets right="16"/>
                            </padding>

                            <Button fx:id="nextInstructionButton"
                                    text="􀆊"
                                    styleClass="carousel-button"/>

                        </StackPane>

                    </right>

                    <!-- OK -->
                    <bottom>

                        <HBox alignment="CENTER_RIGHT">

                            <padding>
                                <Insets right="20" bottom="20"/>
                            </padding>

                            <Button fx:id="instructionsOkButton"
                                    text="OK"
                                    styleClass="carousel-skip-button"/>

                        </HBox>

                    </bottom>

                </BorderPane>

            </StackPane>

        </StackPane>

    </StackPane>

    <!-- Win / lose overlay -->
    <StackPane fx:id="resultOverlay"
               styleClass="overlay-scrim"
               visible="false"
               managed="false">

        <VBox styleClass="overlay-card"
              alignment="CENTER"
              spacing="18"
              maxWidth="420"
              maxHeight="260">

            <Label fx:id="resultTitleLabel"
                   text="YOU WON"
                   styleClass="title-label"/>

            <HBox alignment="CENTER"
                  spacing="12">

                <Button fx:id="resultMenuButton"
                        text="Main menu"
                        styleClass="primary-button"/>

                <Button fx:id="resultReplayButton"
                        text="Play again"
                        styleClass="primary-button"/>
            </HBox>
        </VBox>
    </StackPane>
</StackPane>